# Copy this file to .env and update values
# Provider: openai or deepseek
LLM_PROVIDER=deepseek

# OpenAI settings (used when LLM_PROVIDER=openai)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=

# DeepSeek settings (used when LLM_PROVIDER=deepseek)
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Model + runtime settings
MODEL_NAME=deepseek-chat
TEMPERATURE=0.2

# Bookshelf sync settings
BOOKSHELF_PATH=~/Bookshelf

# PostgreSQL + pgvector (choose one style)
# 1) Full DSN
PGVECTOR_DSN=postgresql://user:password@localhost:5432/agent_db

# 2) Split connection fields (used when PGVECTOR_DSN is empty)
PGVECTOR_HOST=localhost
PGVECTOR_PORT=5432
PGVECTOR_DBNAME=agent_db
PGVECTOR_USER=postgres
PGVECTOR_PASSWORD=postgres
PGVECTOR_SSLMODE=
PGVECTOR_TABLE=knowledge_chunks

# Knowledge ingestion / retrieval tuning
# Chapter-level async analysis concurrency for ingest/sync CLIs
KNOWLEDGE_CHAPTER_ANALYSIS_CONCURRENCY=4

# Incremental sync behavior (sync_bookshelf)
KNOWLEDGE_SYNC_INCREMENTAL=true
KNOWLEDGE_SYNC_AUTO_DELETE_REMOVED=true
KNOWLEDGE_SYNC_HASH_CHECK=true
KNOWLEDGE_SYNC_SHOW_INCREMENTAL_STATS=true
KNOWLEDGE_SYNC_STATE_FILE=memory/bookshelf_sync_state.json

# Default retrieval parameters (used by LangGraph flow and tool fallback)
KNOWLEDGE_TOP_K_DEFAULT=5
KNOWLEDGE_CONTEXT_WINDOW_DEFAULT=3
KNOWLEDGE_RERANK_CANDIDATES_DEFAULT=14

# Local deterministic rerank weights (auto-normalized)
KNOWLEDGE_LOCAL_RERANK_WEIGHT_SEMANTIC=0.5
KNOWLEDGE_LOCAL_RERANK_WEIGHT_CHARACTER=0.35
KNOWLEDGE_LOCAL_RERANK_WEIGHT_TIMELINE=0.15

# Blend weights for final score: LLM rerank vs local rerank (auto-normalized)
KNOWLEDGE_BLEND_WEIGHT_LLM=0.6
KNOWLEDGE_BLEND_WEIGHT_LOCAL=0.4

# Docker sandbox for high-risk tool execution (disabled by default)
DOCKER_SANDBOX_ENABLED=false
DOCKER_SANDBOX_IMAGE=mcr.microsoft.com/devcontainers/python:3.11-bookworm
DOCKER_EXEC_TIMEOUT=30
DOCKER_MEMORY_LIMIT=512m
DOCKER_CPU_LIMIT=1
DOCKER_PIDS_LIMIT=128
DOCKER_NETWORK_MODE=bridge
DOCKER_MAX_COMMAND_CHARS=4000
# Optional persistent mount path for sandbox work files
DOCKER_SANDBOX_WORKDIR=

# LangSmith tracing (optional, recommended for LangGraph observability)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=agent-langgraph
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
